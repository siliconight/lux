[resource]
script = ExtResource("1_preset")
preset_name = &"Gothic Street Night"
description = "Source-era urban gothic night street (Bloodlines-style construction). No sun; dark green-gray FLAT ambient reveals forms and routes while fine detail collapses into graphic darkness. Practicals carry the scene: streetlight/area rigs + emissive sign faces. Sodium-amber highlights, bruised-violet shadows, one magenta accent. Crushed blacks, slightly cool, crisp image: native res, no CRT, dither low. Emissive faces at energy 1.5-3.0 clear the 1.05 glow threshold (mild bloom, legible signs). Wetness stays per-material (pavement only) - default_wetness 0."
sky_top_color = Color(0.03, 0.035, 0.06, 1)
