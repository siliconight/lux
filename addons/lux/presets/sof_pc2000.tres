[resource]
script = ExtResource("1_preset")
preset_name = &"SoF PC2000"
description = "Fourth look family: 'premium PC shooter, 1999-2002' (Soldier of Fortune brief). Sharp, direct, game-like - NOT PS1-chunk and NOT modern-cinematic. CONTRACT: Lux is GRADE-ONLY here. Level geometry keeps its imported per-pixel StandardMaterial3D (bilinear + mipmaps) and is lit by a LightmapGI bake - hard authored light pools with crisp baked shadow edges. Do not role-apply LEVEL with the stylized path; use LuxMaterialApplier.apply_role_lightmapped + the dock's 'Lightmap static' bake (docs/pc2000_bake_runbook.md). Grade: restrained Filmic, exposure just under neutral, saturation 0.9, mild contrast. Glow OFF, dither OFF, CRT OFF, vignette/grain 0, native res bilinear. Flat ambient kept LOW on purpose - the lightmap owns darkness; raise it and you wash out the bake. Light distance fog only; volumetrics are per-location set dressing, not a preset default."
sky_top_color = Color(0.35, 0.45, 0.6, 1)
sky_horizon_color = Color(0.7, 0.68, 0.62, 1)
ground_color = Color(0.3, 0.28, 0.24, 1)
