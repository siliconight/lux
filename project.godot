; Engine configuration file.
; Lux demo project — Godot 4.7, Forward+ (primary target per TDD §8).

config_version=5

[application]

config/name="Lux Rendering Framework"
config/description="Warm, sixth-gen-console-inspired rendering framework for Godot 4.7. Demo project for the Lux addon."
run/main_scene="res://addons/lux/samples/lux_sample_scene.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[editor_plugins]

enabled=PackedStringArray("res://addons/lux/plugin.cfg")

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_environment=""
